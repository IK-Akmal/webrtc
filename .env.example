NODE_ENV=development
CORS_ORIGIN=http://localhost
PORT=3001

# ── PostgreSQL ──────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=webrtc_conf
DB_USER=webrtc
DB_PASS=CHANGE_ME_db_password
DB_SSL=false

# ── JWT ─────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES=7d

# ── STUN / TURN ─────────────────────────────────
# Public STUN (Google) — free, no config needed
STUN_SERVER_URL=stun:stun.l.google.com:19302

# TURN server — required for users behind symmetric NAT / corporate firewalls
# For local dev on Windows/macOS use a hosted service (e.g. Metered.ca free tier)
# For Linux production: run coturn with the static-auth-secret below
TURN_SERVER_URL=turn:your-coturn-host:3478
TURN_SECRET=CHANGE_ME_turn_static_auth_secret

# ── Frontend (Vite build-time vars) ─────────────
VITE_API_BASE_URL=http://localhost/api
VITE_SOCKET_URL=http://localhost
